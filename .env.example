# ─── AgentHive ─────────────────────────────────────────────────────
# Copy to .env and fill in. Defaults handle the rest.

PORT=7700
PUBLIC_URL=http://localhost:7700

# Shared secrets — generate with: openssl rand -hex 32
WEBHOOK_SECRET=change-me
DISPATCH_TOKEN=change-me

# GitHub PAT — fine-grained or classic. Needs write on Issues, PRs,
# Contents, Commit statuses, and read on Metadata + Actions.
GITHUB_TOKEN=

# Claude auth — pick one:
#  A) API key (billed per call).
ANTHROPIC_API_KEY=
#  B) Host creds path (auto-detected from ~/.claude if empty).
CLAUDE_CREDENTIALS_HOST_PATH=

# AgentCore containers.
AGENTCORE_IMAGE=agentcore
DOCKER_NETWORK=agenthive-net
SESSION_STATE_ROOT=./state/sessions
